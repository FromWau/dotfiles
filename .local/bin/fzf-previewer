#!/bin/bash


if [[ "${1:-}" == "--__preview" ]]; then
	file="$2"
	dim="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}"

	case "${file,,}" in
	*.png | *.jpg | *.jpeg | *.webp | *.gif | *.bmp)
		kitten icat --clear --transfer-mode=memory --unicode-placeholder \
			--stdin=no --place="${dim}@0x0" "$file" 2>/dev/null |
			sed '$d' | sed $'$s/$/\e[m/'
		;;
	*)
		bat --color=always "$file" 2>/dev/null || cat -- "$file"
		;;
	esac
	exit 0
fi

exec fzf --preview="$0 --__preview {}" "$@"
